    CHILD.setSize(16, 0, 0, 1);
    CHILD.setSprite(sprite7);
    CHILD.setSpriteTiling(false);
    CHILD.hookDraggedOver(&script_43(widget0, widget1));
    CHILD.setNoClickThrough(1);

    widget1.hookScroll(&script_46(widget0, widget1, MOUSE_X));  // Use MOUSE_X for scroll

    return;
}