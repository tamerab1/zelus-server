    CHILD.setSize(16, 0, 0, 1);  // Adjusted width-based
    CHILD.setSprite(sprite6);
    CHILD.setSpriteTiling(false);
    CHILD.hookDraggedOver(&script_42(widget0, widget1));
    CHILD.setNoClickThrough(1);

