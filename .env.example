# ── Zelus Production Environment ─────────────────────────────────────────────
# Copy this file:  cp .env.example .env
# Then fill in all values marked CHANGE_ME before running docker compose.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=zelus.gg
EMAIL=admin@zelus.gg         # Let's Encrypt renewal notifications
STAGING=0                    # Set to 1 to use LE staging server while testing

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=zelus_db
POSTGRES_USER=zelus_web
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_STRING

# ── FastAPI (zelus-website-api) ───────────────────────────────────────────────
# DATABASE_URL is auto-built from POSTGRES_* vars in docker-compose.yml
# Set GAME_DB_HOST to the private IP of your game server VPS
GAME_DB_HOST=localhost

# Cloudflare Turnstile (get from dash.cloudflare.com → Turnstile)
TURNSTILE_SECRET_KEY=CHANGE_ME_TURNSTILE_SECRET

# Site URL (used in email verification links)
SITE_URL=https://zelus.gg

# Comma-separated allowed CORS origins
CORS_ORIGINS=https://zelus.gg,https://www.zelus.gg

# SMTP — for verification emails (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME@gmail.com
SMTP_PASS=CHANGE_ME_APP_PASSWORD   # Use Gmail App Password, not your real password

# ── React Frontend (build-time args, not runtime) ─────────────────────────────
VITE_API_URL=https://api.zelus.gg
VITE_TURNSTILE_SITE_KEY=CHANGE_ME_TURNSTILE_SITE_KEY   # public key, safe to commit

# ── Game Server ───────────────────────────────────────────────────────────────
# Only needed if running game_server profile on this machine
# GAME_JAVA_OPTS is set in docker-compose.yml; override here if needed
