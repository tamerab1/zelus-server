# ============================================================
# Zelus Website API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Database ──────────────────────────────────────────────
# Local dev (Docker Compose): postgresql://zelus_web:YOUR_PASS@localhost:5432/zelus_db
# Production (VPS):           set via docker-compose environment block
DATABASE_URL=postgresql://zelus_web:YOUR_PASSWORD@localhost:5432/zelus_db

# Game DB host — localhost when API and game server share the same machine
GAME_DB_HOST=localhost

# ── Site / CORS ───────────────────────────────────────────
# Local dev: http://localhost:5173
# Production: https://zelusrsps.com  (no trailing slash)
SITE_URL=http://localhost:5173

# Comma-separated list of origins allowed to call the API.
# Production: set to exactly https://zelusrsps.com
# Webhooks come from Stripe/PayPal servers — they are NOT browser requests
# and are NOT subject to CORS, so you do NOT need to list them here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Cloudflare Turnstile ──────────────────────────────────
# Leave blank in local dev — Turnstile is skipped when the secret is empty.
# Get keys: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=

# ── SMTP (email verification) ─────────────────────────────
# Leave blank in local dev — verification links are printed to the console.
# For Gmail / Google Workspace: you MUST use an App Password, not your regular password.
#   1. Enable 2-Step Verification on the account
#   2. Go to myaccount.google.com → Security → App passwords → create one for "Mail"
#   3. Use the 16-char code it gives you (no spaces) as SMTP_PASS
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USER=support@zelusrsps.com
SMTP_PASS=

# ── Stripe ────────────────────────────────────────────────
# Test keys (prefix sk_test_) from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — created when you add a webhook endpoint in the dashboard.
# For local dev with Stripe CLI:  stripe listen --forward-to localhost:8000/api/webhooks/stripe
# It prints:  whsec_xxxx  — paste that value here.
# For production:  https://dashboard.stripe.com/test/webhooks  → add endpoint →
#   URL: https://api.zelusrsps.com/api/webhooks/stripe
#   Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PayPal ────────────────────────────────────────────────
# Sandbox credentials from: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Sandbox base URL (switch to https://api-m.paypal.com for production)
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Webhook ID — created at: https://developer.paypal.com/dashboard/webhooks/sandbox
# For local dev with ngrok:
#   1. Run: ngrok http 8000
#   2. Copy the https://xxxx.ngrok-free.app URL
#   3. In PayPal developer dashboard → Webhooks → Add webhook:
#      URL: https://xxxx.ngrok-free.app/api/webhooks/paypal
#      Event: PAYMENT.CAPTURE.COMPLETED
#   4. Copy the Webhook ID shown after saving and paste it here.
PAYPAL_WEBHOOK_ID=
